# ── AXIOM Log Server — environment variables ───────────────────────────────────
# Copy this file to .env before running docker compose up --build

# Port to expose on the host (default 7654)
AXIOM_PORT=7654

# Ollama (AI analysis + Ask AI chat)
# Point this at your Ollama instance. host.docker.internal resolves to the
# Docker host on Linux/macOS when extra_hosts is set in docker-compose.yml.
OLLAMA_HOST=http://host.docker.internal:11434

# Gotify push notifications (optional — leave blank to disable)
GOTIFY_HOST=
GOTIFY_TOKEN=
